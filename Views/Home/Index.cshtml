@{
    Layout = "_LayoutPublico";
    ViewData["Title"] = "Bem-vindo a agenda de contatos";
}

<div class="container vh-100 d-flex align-items-center">
    <div class="row w-100 justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="mb-3">Agenda de Contatos</h1>
            <p class="lead mb-4">
                Organize seus contatos de forma simples, rápida e segura.
            </p>

            <a asp-controller="Usuario"
               asp-action="Login"
               class="btn btn-primary btn-lg me-2">
                Login
            </a>

            <a asp-controller="Usuario"
               asp-action="Cadastro"
               class="btn btn-outline-primary btn-lg">
                Cadastro
            </a>
        </div>
    </div>
</div>
