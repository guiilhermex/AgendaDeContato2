@{
    Layout = "_LayoutPublico";
    ViewData["Title"] = "Dashboard - Agenda de Contatos";
}

<div class="container">
    <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom mb-4">
        <div class="container-fluid">
            <span class="navbar-brand fw-semibold">
                Agenda de Contatos
            </span>

            <div class="ms-auto">
                <button id="btnLogout" class="btn btn-outline-danger btn-sm">
                    Sair
                </button>
            </div>
        </div>
    </nav>

    <!-- TÍTULO -->
    <div class="mb-4">
        <h2>Dashboard</h2>
        <p class="text-muted">Gerencie seus contatos e grupos</p>
    </div>

    <!-- AÇÕES -->
    <div class="mb-4 d-flex gap-2">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalContato" id="NovoContato">
            Novo Contato
        </button>

        <button class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#modalGrupo" id="NovoGrupo">
            Novo Grupo
        </button>
    </div>

    <!-- FILTRO CONTATOS -->
    <div class="card-body border-bottom mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-bold">Buscar contato</label>
                <input type="text"
                       class="form-control"
                       id="FiltroContatoNome"
                       placeholder="Nome do contato">
            </div>
            <div class="col-md-1">
                <button class="btn btn-outline-primary w-100" id="btnFiltrarContato">
                    Filtrar
                </button>
            </div>
        </div>
    </div>

    <!-- ================= CONTATOS ================= -->
    <div class="card mb-5">
        <div class="card-header fw-bold text-center">
            Contatos
        </div>

        <div class="table-responsive">
            <table class="table table-striped mb-0 text-center align-middle" id="tabelaContato">
                <thead>
                    <tr>
                        <th class="fw-bold">Nome</th>
                        <th class="fw-bold">Email</th>
                        <th class="fw-bold">Telefone</th>
                        <th class="fw-bold">Grupo</th>
                        <th class="fw-bold" style="width: 150px;">Ações</th>
                    </tr>
                </thead>
                <tbody id="dadosTabela">
                    <!-- preenchido via JS -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- FILTRO GRUPOS -->
    <div class="card-body border-bottom mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-bold">Buscar grupo</label>
                <input type="text"
                       class="form-control"
                       id="FiltroGrupoNome"
                       placeholder="Nome do grupo">
            </div>
            <div class="col-md-1">
                <button class="btn btn-outline-secondary w-100" id="btnFiltrarGrupo">
                    Filtrar
                </button>
            </div>
        </div>
    </div>

    <!-- ================= GRUPOS ================= -->
    <div class="card mb-5">
        <div class="card-header fw-bold text-center">
            Grupos
        </div>

        <div class="table-responsive">
            <table class="table table-striped mb-0 text-center align-middle" id="tabelaGrupo">
                <thead>
                    <tr>
                        <th class="fw-bold">Nome do Grupo</th>
                        <th class="fw-bold" style="width: 150px;">Ações</th>
                    </tr>
                </thead>
                <tbody id="dadosTabelaGrupo">
                    <!-- preenchido via JS -->
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- MODAL CONTATO -->
<div class="modal fade" id="modalContato" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="tituloModalContato">Contato</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="formContato">
                    <input type="hidden" id="ContatoId" />

                    <div class="mb-3">
                        <label>Nome</label>
                        <input type="text" class="form-control" id="ContatoNome" required />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" class="form-control" id="ContatoEmail" required />
                    </div>

                    <div class="mb-3">
                        <label>Telefone</label>
                        <input type="text" class="form-control" id="ContatoTelefone" />
                    </div>
                    <div class="mb-3">
                        <label>Grupo</label>
                        <input type="text" class="form-control" id="ContatoGrupo" />
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" id="btnSalvarContato">Salvar</button>
            </div>

        </div>
    </div>
</div>

<!-- MODAL GRUPO -->
<div class="modal fade" id="modalGrupo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="tituloModalGrupo">Grupo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="formGrupo">
                    <input type="hidden" id="GrupoId" />

                    <div class="mb-3">
                        <label>Nome do Grupo</label>
                        <input type="text" class="form-control" id="GrupoNome" required />
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" id="btnSalvarGrupo">Salvar</button>
            </div>

        </div>
    </div>
</div>

<!-- MODAL CONFIRMAÇÃO -->
<div class="modal fade" id="modalConfirmacao" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirmar exclusão</h5>
            </div>

            <div class="modal-body text-center">
                <p>Deseja realmente excluir?</p>
            </div>

            <div class="modal-footer justify-content-center">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Não</button>
                <button class="btn btn-danger" id="btnConfirmarExclusao">Sim</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/Site.js"></script>
    <script src="/js/Contato.js"></script>
    <script src="/js/Grupo.js"></script>
    <script src="/js/Dashboard.js"></script>
}
