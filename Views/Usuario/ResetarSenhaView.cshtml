@model AgendaContato.ViewModels.Usuario.UsuarioResetarSenhaViewModel
@{
    ViewData["Title"] = "Esqueceu a Senha";
}
<h2>Resetar Senha</h2>

<form asp-action="ResetarSenha" method="post">
    <div class="form-group">
        <label asp-for="Senha"></label>
        <input asp-for="Senha" class="form-control" />
        <span asp-validation-for="Senha" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ConfirmarSenha"></label>
        <input asp-for="ConfirmarSenha" class="form-control" />
        <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
    </div>
    <input type="hidden" asp-for="Token"/>
    <input type="hidden" asp-for="Email"/>
    <button type="submit" class="btn btn-primary">Resetar</button>
</form>